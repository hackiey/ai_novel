MONGODB_URI=mongodb://localhost:27017/ai_novel?directConnection=true
PORT=3001

# LLM API keys (provider-specific or generic)
# The server checks for <PROVIDER>_API_KEY first, then falls back to LLM_API_KEY
LLM_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Embedding service config (DashScope OpenAI-compatible)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024

# Model format: "provider:modelId" (e.g. "openai:gpt-4o", "anthropic:claude-sonnet-4-6")
AVAILABLE_MODELS=openai:gpt-4o,anthropic:claude-sonnet-4-6
DEFAULT_MODEL=openai:gpt-4o
DEFAULT_REASONING=medium

JWT_SECRET=
JWT_EXPIRES_IN=30d
