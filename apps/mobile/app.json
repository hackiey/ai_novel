{
  "expo": {
    "name": "AI Creator",
    "slug": "ai-creator",
    "version": "0.2.1",
    "scheme": "ai-creator",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "default",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.anonymous.aicreator"
    },
    "ios": {
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
